# Upstash Redis (both services)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# GCS (both services)
GCS_BUCKET=annemusic-videos
# Set to "public" to return https://storage.googleapis.com/... URLs;
# set to "signed" to return signed URLs with 24h expiry.
GCS_URL_MODE=public

# API service only
GCP_PROJECT=your-gcp-project
GCP_REGION=us-central1
TASKS_QUEUE=karaoke-jobs
WORKER_URL=https://worker-xxxxx-uc.a.run.app
TASKS_INVOKER_SA=annemusic-api@your-gcp-project.iam.gserviceaccount.com
# Comma-separated origins allowed by CORS. Set to your Firebase Hosting URL in prod.
CORS_ORIGINS=*

# Worker service only
# Set to "1" to bypass Cloud Tasks OIDC verification (local dev only).
SKIP_AUTH=0
# Audience the worker expects in the OIDC token (its own Cloud Run URL).
OIDC_AUDIENCE=https://worker-xxxxx-uc.a.run.app
# Whisper model size: tiny|base|small|medium|large-v3
WHISPER_MODEL=small
