{
  "name": "@annemusic/stage-compose",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "DEV_FS_ROOT=${DEV_FS_ROOT:-/tmp/annemusic-compose-test} tsx --test tests/*.test.ts",
    "bench": "DEV_FS_ROOT=${DEV_FS_ROOT:-/tmp/annemusic-compose-bench} tsx bench/run.mjs"
  },
  "dependencies": {
    "@annemusic/contracts": "workspace:*",
    "@annemusic/shared-ts": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
