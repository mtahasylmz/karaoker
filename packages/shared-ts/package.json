{
  "name": "@annemusic/shared-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "default": "./dist/logger.js"
    },
    "./redis": {
      "types": "./dist/redis.d.ts",
      "default": "./dist/redis.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "default": "./dist/env.js"
    },
    "./gcs": {
      "types": "./dist/gcs.d.ts",
      "default": "./dist/gcs.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@annemusic/contracts": "workspace:*",
    "@upstash/redis": "^1.34.3",
    "@google-cloud/storage": "^7.14.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^20.17.0"
  }
}
