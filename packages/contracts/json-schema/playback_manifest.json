{
  "$ref": "#/definitions/PlaybackManifest",
  "definitions": {
    "PlaybackManifest": {
      "type": "object",
      "properties": {
        "job_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{12,32}$"
        },
        "video_url": {
          "type": "string"
        },
        "instrumental_url": {
          "type": "string"
        },
        "ass_url": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "duration": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "created_at": {
          "type": "integer"
        },
        "lines": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "start": {
                "type": "number",
                "minimum": 0
              },
              "end": {
                "type": "number",
                "minimum": 0
              },
              "words": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "text": {
                      "type": "string"
                    },
                    "start": {
                      "type": "number",
                      "minimum": 0
                    },
                    "end": {
                      "type": "number",
                      "minimum": 0
                    },
                    "score": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    }
                  },
                  "required": [
                    "text",
                    "start",
                    "end"
                  ],
                  "additionalProperties": false
                }
              }
            },
            "required": [
              "start",
              "end",
              "words"
            ],
            "additionalProperties": false
          }
        },
        "vocal_activity": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "start": {
                "type": "number",
                "minimum": 0
              },
              "end": {
                "type": "number",
                "minimum": 0
              },
              "kind": {
                "type": "string",
                "enum": [
                  "vocals",
                  "instrumental"
                ]
              }
            },
            "required": [
              "start",
              "end",
              "kind"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "job_id",
        "video_url",
        "instrumental_url",
        "ass_url",
        "created_at",
        "lines",
        "vocal_activity"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
