{
  "$ref": "#/definitions/AlignResponse",
  "definitions": {
    "AlignResponse": {
      "type": "object",
      "properties": {
        "job_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{12,32}$"
        },
        "stage": {
          "type": "string",
          "const": "align"
        },
        "started_at": {
          "type": "integer",
          "minimum": 0
        },
        "finished_at": {
          "type": "integer",
          "minimum": 0
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "diagnostics": {
          "type": "object",
          "additionalProperties": {}
        },
        "words": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": {
                "type": "string"
              },
              "start": {
                "type": "number",
                "minimum": 0
              },
              "end": {
                "type": "number",
                "minimum": 0
              },
              "score": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            },
            "required": [
              "text",
              "start",
              "end"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "job_id",
        "stage",
        "started_at",
        "finished_at",
        "duration_ms",
        "words"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
