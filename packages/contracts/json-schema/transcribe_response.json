{
  "$ref": "#/definitions/TranscribeResponse",
  "definitions": {
    "TranscribeResponse": {
      "type": "object",
      "properties": {
        "job_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{12,32}$"
        },
        "stage": {
          "type": "string",
          "const": "transcribe"
        },
        "started_at": {
          "type": "integer",
          "minimum": 0
        },
        "finished_at": {
          "type": "integer",
          "minimum": 0
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "diagnostics": {
          "type": "object",
          "additionalProperties": {}
        },
        "language": {
          "type": "string"
        },
        "segments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": {
                "type": "string"
              },
              "start": {
                "type": "number",
                "minimum": 0
              },
              "end": {
                "type": "number",
                "minimum": 0
              }
            },
            "required": [
              "text",
              "start",
              "end"
            ],
            "additionalProperties": false
          }
        },
        "vocal_activity": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "start": {
                "type": "number",
                "minimum": 0
              },
              "end": {
                "type": "number",
                "minimum": 0
              },
              "kind": {
                "type": "string",
                "enum": [
                  "vocals",
                  "instrumental"
                ]
              }
            },
            "required": [
              "start",
              "end",
              "kind"
            ],
            "additionalProperties": false
          }
        },
        "source": {
          "type": "string",
          "enum": [
            "qwen3",
            "whisper"
          ]
        },
        "model_used": {
          "type": "string"
        }
      },
      "required": [
        "job_id",
        "stage",
        "started_at",
        "finished_at",
        "duration_ms",
        "language",
        "segments",
        "vocal_activity",
        "source",
        "model_used"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
