{
  "$ref": "#/definitions/ComposeResponse",
  "definitions": {
    "ComposeResponse": {
      "type": "object",
      "properties": {
        "job_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{12,32}$"
        },
        "stage": {
          "type": "string",
          "const": "compose"
        },
        "started_at": {
          "type": "integer",
          "minimum": 0
        },
        "finished_at": {
          "type": "integer",
          "minimum": 0
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "diagnostics": {
          "type": "object",
          "additionalProperties": {}
        },
        "manifest_uri": {
          "type": "string",
          "pattern": "^gs:\\/\\/[a-z0-9_.-]+\\/[^\\0]+$"
        },
        "manifest_url": {
          "type": "string"
        },
        "ass_uri": {
          "type": "string",
          "pattern": "^gs:\\/\\/[a-z0-9_.-]+\\/[^\\0]+$"
        }
      },
      "required": [
        "job_id",
        "stage",
        "started_at",
        "finished_at",
        "duration_ms",
        "manifest_uri",
        "manifest_url",
        "ass_uri"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
