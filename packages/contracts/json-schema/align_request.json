{
  "$ref": "#/definitions/AlignRequest",
  "definitions": {
    "AlignRequest": {
      "type": "object",
      "properties": {
        "job_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{12,32}$"
        },
        "vocals_uri": {
          "type": "string",
          "pattern": "^gs:\\/\\/[a-z0-9_.-]+\\/[^\\0]+$"
        },
        "segments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": {
                "type": "string"
              },
              "start": {
                "type": "number",
                "minimum": 0
              },
              "end": {
                "type": "number",
                "minimum": 0
              }
            },
            "required": [
              "text",
              "start",
              "end"
            ],
            "additionalProperties": false
          }
        },
        "language": {
          "type": "string"
        },
        "vocal_activity": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "start": {
                "type": "number",
                "minimum": 0
              },
              "end": {
                "type": "number",
                "minimum": 0
              },
              "kind": {
                "type": "string",
                "enum": [
                  "vocals",
                  "instrumental"
                ]
              }
            },
            "required": [
              "start",
              "end",
              "kind"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "job_id",
        "vocals_uri",
        "segments",
        "language",
        "vocal_activity"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
