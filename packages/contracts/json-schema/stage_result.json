{
  "$ref": "#/definitions/StageResult",
  "definitions": {
    "StageResult": {
      "type": "object",
      "properties": {
        "job_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{12,32}$"
        },
        "stage": {
          "type": "string",
          "enum": [
            "separate",
            "transcribe",
            "align",
            "compose",
            "record-mix"
          ]
        },
        "started_at": {
          "type": "integer",
          "minimum": 0
        },
        "finished_at": {
          "type": "integer",
          "minimum": 0
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "diagnostics": {
          "type": "object",
          "additionalProperties": {}
        }
      },
      "required": [
        "job_id",
        "stage",
        "started_at",
        "finished_at",
        "duration_ms"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
