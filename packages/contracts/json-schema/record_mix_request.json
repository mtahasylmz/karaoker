{
  "$ref": "#/definitions/RecordMixRequest",
  "definitions": {
    "RecordMixRequest": {
      "type": "object",
      "properties": {
        "job_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{12,32}$"
        },
        "recording_uri": {
          "type": "string",
          "pattern": "^gs:\\/\\/[a-z0-9_.-]+\\/[^\\0]+$"
        },
        "instrumental_uri": {
          "type": "string",
          "pattern": "^gs:\\/\\/[a-z0-9_.-]+\\/[^\\0]+$"
        },
        "vocals_uri": {
          "type": "string",
          "pattern": "^gs:\\/\\/[a-z0-9_.-]+\\/[^\\0]+$"
        },
        "autotune": {
          "type": "string",
          "enum": [
            "off",
            "smooth",
            "snap"
          ],
          "default": "off"
        },
        "clean_bleed": {
          "type": "boolean",
          "default": true
        },
        "gain_db": {
          "type": "number",
          "minimum": -24,
          "maximum": 24,
          "default": 0
        },
        "mix": {
          "type": "object",
          "properties": {
            "vocal_gain_db": {
              "type": "number",
              "minimum": -12,
              "maximum": 12
            },
            "instrumental_gain_db": {
              "type": "number",
              "minimum": -12,
              "maximum": 12
            },
            "reverb_wet": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "duck_db": {
              "type": "number",
              "minimum": 0,
              "maximum": 12
            },
            "presence_db": {
              "type": "number",
              "minimum": -3,
              "maximum": 6
            }
          },
          "additionalProperties": false
        }
      },
      "required": [
        "job_id",
        "recording_uri",
        "instrumental_uri"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
