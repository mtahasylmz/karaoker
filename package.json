{
  "name": "annemusic",
  "private": true,
  "version": "0.1.0",
  "description": "Karaoke-video generator: stages + contracts monorepo",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "check": "pnpm -r --if-present run check",
    "dev": "concurrently -k -n qstash,stub,api,orc,web -c cyan,magenta,green,yellow,blue \"pnpm dev:qstash\" \"pnpm dev:stub\" \"pnpm dev:api\" \"pnpm dev:orc\" \"pnpm dev:web\"",
    "dev:qstash": "npx -y @upstash/qstash-cli@latest dev",
    "dev:stub": "pnpm --filter @annemusic/stage-stub dev",
    "dev:api": "pnpm --filter @annemusic/api dev",
    "dev:orc": "pnpm --filter @annemusic/orchestrator dev",
    "dev:web": "pnpm --filter @annemusic/web dev",
    "logs": "node tools/logs/dist/cli.js",
    "contracts:check": "pnpm --filter @annemusic/contracts run check",
    "contracts:build": "pnpm --filter @annemusic/contracts run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3"
  }
}
