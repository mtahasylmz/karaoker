# Upstash Redis — state store + log streams
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# Upstash QStash — powers @upstash/workflow. In local dev these point at the
# `qstash-dev` service in docker-compose (http://localhost:8080).
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# GCP + GCS
GCP_PROJECT=karaoke-494118
GCP_REGION=us-central1
GCS_BUCKET=annemusic-videos-karaoke-494118
# "public" returns https://storage.googleapis.com/... URLs; "signed" issues 24h signed URLs.
GCS_URL_MODE=public
# Path to a service-account JSON key for local dev. In Cloud Run this is unset
# and the ambient runtime SA is used automatically.
GOOGLE_APPLICATION_CREDENTIALS=

# Orchestrator → stage service URLs. In local dev these are docker-compose
# service names; in Cloud Run they're the run.app URLs.
SEPARATE_URL=http://separate:8080
TRANSCRIBE_URL=http://transcribe:8080
ALIGN_URL=http://align:8080
COMPOSE_URL=http://compose:8080
RECORD_MIX_URL=http://record-mix:8080

# Default per-stage model selection. Each stage treats these as defaults that
# a request-body `model` field can override.
SEPARATE_MODEL=htdemucs
WHISPER_MODEL=large-v3
ALIGN_MODEL=whisperx

# Orchestrator identity for OIDC-signed calls to stages (prod only)
TASKS_INVOKER_SA=annemusic-orchestrator@karaoke-494118.iam.gserviceaccount.com

# CORS for the api (comma-separated origins, "*" in dev)
CORS_ORIGINS=*

# Environment tag — "local" suppresses OIDC checks and reads QSTASH_URL override.
NODE_ENV=local
